# MongoDB Configuration
MONGODB_URI=mongodb://start_app:app_password@localhost:27017/start_beta
MONGODB_ADMIN_URI=mongodb://admin:password123@localhost:27017/admin

# Ollama Configuration (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Проверка локальной Ollama: ollama list
# Загрузка модели: ollama pull llama3.1

# App Configuration
APP_ENV=development
LOG_LEVEL=INFO

# File Processing Settings
MAX_CONTEXT_LINES=50
MAX_FILE_SIZE=5000
CONTEXT_WINDOW_SIZE=5
SUPPORTED_EXTENSIONS=.py,.js,.html,.css,.md,.txt,.json,.xml
